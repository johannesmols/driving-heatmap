# Copy this file to .env and fill in the values. Never commit .env.

# ─── PostgreSQL ───────────────────────────────────────────
# This password is only used within the Docker network. Pick anything.
DB_PASSWORD=change_me

# ─── Connected Cars API ───────────────────────────────────
# Your Connected Cars account credentials (same as the car manufacturer app).
CC_EMAIL=
CC_PASSWORD=

# App namespace — determines which Connected Cars API partition to query.
# Known namespaces:
#   semler:minvolkswagen  — Min Volkswagen (Denmark)
#   semler:minskoda        — MySkoda
CC_NAMESPACE=semler:minvolkswagen

# ─── Sync scheduling ──────────────────────────────────────
# How often (in hours) the sync service fetches new trips.
# First sync runs immediately on container start (full backfill).
SYNC_INTERVAL_HOURS=6

# ─── Frontend ─────────────────────────────────────────────
# Host port for the web UI. Default: 3000.
# FRONTEND_PORT=3000

# ─── pgAdmin (dev only — requires compose.override.yaml) ──
# Web UI at http://localhost:5050
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=change_me
